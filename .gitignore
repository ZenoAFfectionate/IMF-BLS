# ---------------------------------------------------------------
# Python
# ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ---------------------------------------------------------------
# Virtual envs
# ---------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------
# pytest / coverage
# ---------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---------------------------------------------------------------
# Editor / OS
# ---------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ---------------------------------------------------------------
# Data — 通过 scripts/download_datasets.sh 重新获取，不入库
# ---------------------------------------------------------------
data/*
!data/.gitkeep
!data/README.md

# ---------------------------------------------------------------
# Experiment outputs — main.py / reproduce.py 运行后自动生成
# ---------------------------------------------------------------
results/*
!results/.gitkeep

# ---------------------------------------------------------------
# Logs / large artefacts
# ---------------------------------------------------------------
*.log
*.tmp
*.pkl
*.npy
*.npz
*.h5
*.zip

# ---------------------------------------------------------------
# Paper sources（如需公开复现可保留 PDF，注释下行即可）
# ---------------------------------------------------------------
paper.txt
paper.pdf
